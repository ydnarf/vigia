# Token del bot — créalo hablando con @BotFather en Telegram
TELEGRAM_TOKEN=

# API key de FRED — gratis en https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Cada cuántos minutos se reevalúa el régimen (opcional, default 30)
CHECK_INTERVAL_MIN=30

# Dónde persistir el estado (opcional, default estado.json)
STATE_PATH=estado.json

# Pon 1 para correr con datos sintéticos, sin FRED_API_KEY (opcional)
VIGIA_DEMO=
